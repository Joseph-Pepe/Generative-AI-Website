# ==========================================
# 🧠 Google Gemini AI & Model Settings
# ==========================================

# Google AI Studio API Key with Lyria 3 Model Access
GOOGLE_GEMINI_API_KEY="GEMINI_LYRIA_API_KEY"

# Note: In the @google/genai SDK, you can also omit 'models/' and just use 'lyria-3-pro-preview' instead of 'models/lyria-3-pro-preview'
LYRIA_MODEL_VERSION="lyria-3-pro-preview"

# ===================================================
# 🔌 Backend Gateway & Database (Server-Only Secrets)
# ===================================================

# The Express gateway will bind to this explicit backend port:
BACKEND_PORT=8000

# Database: Actual connection string pointing to your local Docker Postgres instance or cloud database.
DATABASE_URL="postgresql://db_user:db_password@localhost:5432/database_name"

# =============================================================
# 🌐 Client-Side Gateway Bridges (Exposed to Browser via VITE_)
# =============================================================

# Backend Gateway URL: Point frontend requests to the Backend Gateway on Port 8000
VITE_API_GATEWAY_URL="http://localhost:8000"
VITE_WS_GATEWAY_URL="ws://localhost:8000/ws"

# ======================================================
# 🎛️ DAW Feature Flags & DSP Config (Exposed to Browser)
# ======================================================

# Feature Flags:
VITE_ENABLE_CLIENT_SIDE_DEMIXING=true
VITE_AUDIO_BUFFER_SIZE=4096

# ==========================================
# 🖥️ Frontend Dev Server Ports
# ==========================================

# Vite reads VITE_PORT or package.json CLI flags (--port 3000)
VITE_HOST_PORT=3000
VITE_MFE_GENERATOR_PORT=3001
VITE_MFE_EDITOR_PORT=3003